# Supabase — create a project at https://supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key

# CryptoCompare — get a free key at https://min-api.cryptocompare.com
VITE_APP_API_KEY=your-cryptocompare-api-key

# Cloudinary — https://cloudinary.com (unsigned upload preset, no secret needed)
VITE_APP_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset-name
VITE_APP_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
